APP_DEBUG = true
APP_TRACE = true

[APP]
DEFAULT_TIMEZONE = Asia/Shanghai

[DATABASE]
TYPE = mysql
HOSTNAME = 127.0.0.1
DATABASE = xiaomotui_test
USERNAME = root
PASSWORD =
HOSTPORT = 3306
CHARSET = utf8mb4
COLLATION = utf8mb4_unicode_ci
DEBUG = true
PREFIX = xmt_test_
TIMEOUT = 30
PERSISTENT = false
BREAK_RECONNECT = true
FIELDS_STRICT = true
FIELDS_CACHE = false
TRIGGER_SQL = true

# 测试环境使用较小的连接池
POOL.MIN_CONNECTIONS = 1
POOL.MAX_CONNECTIONS = 5
POOL.CONNECT_TIMEOUT = 10.0
POOL.WAIT_TIMEOUT = 3.0
POOL.HEARTBEAT = 60
POOL.MAX_IDLE_TIME = 60

# 测试数据库配置
TEST.HOSTNAME = 127.0.0.1
TEST.DATABASE = xiaomotui_test
TEST.USERNAME = root
TEST.PASSWORD =
TEST.HOSTPORT = 3306

[REDIS]
HOST = 127.0.0.1
PORT = 6379
PASSWORD =
SELECT = 1
TIMEOUT = 5.0
READ_TIMEOUT = 3.0
EXPIRE = 0
PERSISTENT = false
PREFIX = xmt:test:
RETRY_TIMES = 3
RETRY_INTERVAL = 100

# 测试环境使用较小的Redis连接池
POOL.MIN_CONNECTIONS = 1
POOL.MAX_CONNECTIONS = 3
POOL.CONNECT_TIMEOUT = 10.0
POOL.WAIT_TIMEOUT = 3.0
POOL.HEARTBEAT = 30
POOL.MAX_IDLE_TIME = 60

# Redis选项配置
TCP_NODELAY = true
SO_SNDBUF = 131072
SO_RCVBUF = 131072
TCP_KEEPALIVE = true

[CACHE]
DRIVER = redis

[QUEUE]
DRIVER = sync

[SESSION]
TYPE = file
AUTO_START = true

[LANG]
DEFAULT_LANG = zh-cn

[JWT]
SECRET_KEY = test_jwt_secret_key_for_testing_only
EXPIRE_TIME = 3600
REFRESH_EXPIRE_TIME = 7200

[WECHAT]
APP_ID = test_app_id
APP_SECRET = test_app_secret
MINI_APP_ID = test_mini_app_id
MINI_APP_SECRET = test_mini_app_secret

[OSS]
ACCESS_ID = test_access_id
ACCESS_SECRET = test_access_secret
BUCKET = test_bucket
ENDPOINT = test_endpoint
URL = test_url
PREFIX = xiaomotui/test/
IS_CNAME = false

[QINIU]
ACCESS_KEY = test_access_key
SECRET_KEY = test_secret_key
BUCKET = test_bucket
URL = test_url

[AI]
BAIDU_API_KEY = test_baidu_api_key
BAIDU_SECRET_KEY = test_baidu_secret_key
IFLYTEK_APP_ID = test_iflytek_app_id
IFLYTEK_API_KEY = test_iflytek_api_key
IFLYTEK_API_SECRET = test_iflytek_api_secret

[MAIL]
SMTP_HOST = localhost
SMTP_PORT = 1025
SMTP_USER =
SMTP_PASS =
FROM_EMAIL = test@xiaomotui.local
FROM_NAME = 小磨推测试

[LOG]
CHANNEL = file
LEVEL = debug
PATH = runtime/log/test/
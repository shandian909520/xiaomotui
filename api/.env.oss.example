# ====================================
# OSS对象存储配置示例
# ====================================

# 默认存储驱动 (aliyun, qiniu, tencent, aws, local)
# 开发环境使用local,生产环境根据实际情况选择
OSS_DRIVER=local

# ====================================
# 全局配置
# ====================================
OSS_TIMEOUT=60
OSS_RETRY=3
OSS_CHUNK_SIZE=5242880
OSS_MAX_FILE_SIZE=5368709120
OSS_USE_HTTPS=true
OSS_ENABLE_LOG=true

# ====================================
# 阿里云OSS配置
# ====================================
OSS_ALIYUN_ENABLED=false
OSS_ALIYUN_ACCESS_KEY=your_aliyun_access_key
OSS_ALIYUN_SECRET_KEY=your_aliyun_secret_key
OSS_ALIYUN_BUCKET=your_aliyun_bucket
OSS_ALIYUN_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_ALIYUN_INTERNAL_ENDPOINT=
OSS_ALIYUN_CDN_DOMAIN=
OSS_ALIYUN_PREFIX=uploads/
OSS_ALIYUN_IS_CNAME=false
OSS_ALIYUN_SECURITY_TOKEN=

# ====================================
# 七牛云配置
# ====================================
OSS_QINIU_ENABLED=false
OSS_QINIU_ACCESS_KEY=your_qiniu_access_key
OSS_QINIU_SECRET_KEY=your_qiniu_secret_key
OSS_QINIU_BUCKET=your_qiniu_bucket
OSS_QINIU_DOMAIN=https://cdn.example.com
OSS_QINIU_PREFIX=uploads/
OSS_QINIU_ZONE=z0

# ====================================
# 腾讯云COS配置
# ====================================
OSS_TENCENT_ENABLED=false
OSS_TENCENT_SECRET_ID=your_tencent_secret_id
OSS_TENCENT_SECRET_KEY=your_tencent_secret_key
OSS_TENCENT_BUCKET=your_tencent_bucket-1234567890
OSS_TENCENT_REGION=ap-guangzhou
OSS_TENCENT_CDN_DOMAIN=
OSS_TENCENT_PREFIX=uploads/
OSS_TENCENT_SCHEMA=https
OSS_TENCENT_TIMEOUT=60

# ====================================
# AWS S3配置
# ====================================
OSS_AWS_ENABLED=false
OSS_AWS_ACCESS_KEY=your_aws_access_key
OSS_AWS_SECRET_KEY=your_aws_secret_key
OSS_AWS_BUCKET=your_aws_bucket
OSS_AWS_REGION=us-east-1
OSS_AWS_ENDPOINT=https://s3.amazonaws.com
OSS_AWS_CDN_DOMAIN=
OSS_AWS_PREFIX=uploads/
OSS_AWS_PATH_STYLE=false
OSS_AWS_USE_ACCELERATE=false

# ====================================
# 本地存储配置(开发环境)
# ====================================
OSS_LOCAL_ENABLED=true
OSS_LOCAL_ROOT_PATH=public/uploads
OSS_LOCAL_URL_PREFIX=/uploads
OSS_LOCAL_PREFIX=
OSS_LOCAL_DIR_PERMISSIONS=0755
OSS_LOCAL_FILE_PERMISSIONS=0644

# ====================================
# 缩略图配置
# ====================================
OSS_THUMBNAIL_ENABLED=true
OSS_THUMBNAIL_DRIVER=gd
OSS_THUMBNAIL_QUALITY=85
OSS_THUMBNAIL_FORMAT=jpg
OSS_THUMBNAIL_BACKGROUND=#ffffff

# ====================================
# 文件验证配置
# ====================================
OSS_VALIDATION_MAX_SIZE=5368709120
OSS_VALIDATION_SCAN_VIRUS=false

# ====================================
# 上传进度回调配置
# ====================================
OSS_PROGRESS_ENABLED=true
OSS_PROGRESS_CALLBACK_URL=
OSS_PROGRESS_REPORT_INTERVAL=10

# ====================================
# 签名URL配置
# ====================================
OSS_SIGNED_URL_EXPIRES=3600
OSS_SIGNED_URL_PRIVATE=false

# ====================================
# CDN配置
# ====================================
OSS_CDN_ENABLED=false
OSS_CDN_PROVIDER=aliyun
OSS_CDN_DOMAIN=cdn.example.com
OSS_CDN_HTTPS=true

# ====================================
# 日志配置
# ====================================
OSS_LOG_ENABLED=true
OSS_LOG_CHANNEL=file
OSS_LOG_LEVEL=info

# 邮件配置示例
# 将此配置复制到 .env 文件并根据实际情况修改

# 邮件驱动（smtp）
EMAIL_DRIVER=smtp

# SMTP服务器配置
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_USERNAME=your-email@qq.com
EMAIL_PASSWORD=your-smtp-password

# 发件人信息
EMAIL_FROM_ADDRESS=noreply@xiaomotui.com
EMAIL_FROM_NAME=小魔推

# 加密方式（ssl 或 tls）
EMAIL_ENCRYPTION=ssl

# SSL验证
EMAIL_VERIFY_PEER=true

# 调试模式（生产环境建议设为false）
EMAIL_DEBUG=false

# 邮件队列配置
EMAIL_QUEUE_ENABLED=true

# 告警邮件配置
EMAIL_ALERT_ENABLED=true
EMAIL_ALERT_TO=admin@xiaomotui.com,monitor@xiaomotui.com

# 测试模式（true时不实际发送邮件）
EMAIL_TEST_MODE=false

SMTP_HOST =
SMTP_PORT = 587
SMTP_USER =
SMTP_PASS =
FROM_EMAIL =
FROM_NAME = 小磨推

[LOG]
CHANNEL = file

[MONITOR]
# 健康检查配置
HEALTH_CHECK.ENABLED = true
HEALTH_CHECK.INTERVAL = 30
HEALTH_CHECK.TIMEOUT = 5
HEALTH_CHECK.MAX_RETRIES = 3
HEALTH_CHECK.RETRY_INTERVAL = 1

# 数据库监控配置
DATABASE.ENABLED = true
DATABASE.CONNECTION_TIMEOUT_THRESHOLD = 10
DATABASE.QUERY_TIMEOUT_THRESHOLD = 30
DATABASE.SLOW_QUERY_THRESHOLD = 2
DATABASE.POOL.MIN_CONNECTIONS_WARNING = 2
DATABASE.POOL.MAX_CONNECTIONS_WARNING = 0.9
DATABASE.POOL.WAIT_TIME_WARNING = 5
DATABASE.QUERY_COUNTER = true
DATABASE.CONNECTION_COUNTER = true
DATABASE.ERROR_COUNTER = true

# Redis监控配置
REDIS.ENABLED = true
REDIS.CONNECTION_TIMEOUT_THRESHOLD = 5
REDIS.COMMAND_TIMEOUT_THRESHOLD = 1
REDIS.MEMORY_WARNING_THRESHOLD = 1073741824
REDIS.POOL.MIN_CONNECTIONS_WARNING = 1
REDIS.POOL.MAX_CONNECTIONS_WARNING = 0.9
REDIS.POOL.WAIT_TIME_WARNING = 3
REDIS.COMMAND_COUNTER = true
REDIS.CONNECTION_COUNTER = true
REDIS.ERROR_COUNTER = true
REDIS.MEMORY_MONITORING = true

# 告警配置
ALERTS.ENABLED = true
ALERTS.EMAIL.ENABLED = false
ALERTS.EMAIL.RECIPIENTS = admin@xiaomotui.com
ALERTS.EMAIL.SUBJECT_PREFIX = [小磨推监控]
ALERTS.LOG.ENABLED = true
ALERTS.LOG.LEVEL = error
ALERTS.LOG.CHANNEL = monitor
ALERTS.WECHAT.ENABLED = false
ALERTS.WECHAT.WEBHOOK_URL =
ALERTS.RATE_LIMIT = 300

# 监控数据存储配置
STORAGE.TYPE = redis
STORAGE.RETENTION_TIME = 604800
STORAGE.COMPRESSION = true
STORAGE.REDIS.KEY_PREFIX = monitor:
STORAGE.REDIS.CONNECTION = default
STORAGE.FILE.PATH = runtime/monitor
STORAGE.FILE.FORMAT = json
STORAGE.DATABASE.TABLE = monitor_data
STORAGE.DATABASE.CONNECTION = default

# API监控配置
API.ENABLED = true
API.RESPONSE_TIME_THRESHOLD = 1000
API.ERROR_RATE_THRESHOLD = 5
API.STATUS_CODES.ENABLED = true
API.STATUS_CODES.CODES = 400,401,403,404,405,500,502,503,504

# 系统资源监控
SYSTEM.ENABLED = true
SYSTEM.CPU_THRESHOLD = 80
SYSTEM.MEMORY_THRESHOLD = 85
SYSTEM.DISK_THRESHOLD = 90
SYSTEM.CHECK_INTERVAL = 60
[ADMIN]
# ⚠️ 警告: 生产环境必须修改管理员密码!
# 建议使用至少16位包含大小写字母、数字和特殊字符的强密码
# 示例: YourStrongPassword@2024!
ADMIN_USERNAME = admin
ADMIN_PASSWORD = YourStrongPassword@2024!
ADMIN_PASSWORD_HASH =
ADMIN_JWT_SECRET =
ADMIN_JWT_EXPIRE = 86400


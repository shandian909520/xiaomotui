APP_DEBUG = true
APP_TRACE = false

[APP]
DEFAULT_TIMEZONE = Asia/Shanghai

[DATABASE]
TYPE = mysql
HOSTNAME = 127.0.0.1
DATABASE = xiaomotui
USERNAME = root
PASSWORD =
HOSTPORT = 3306
CHARSET = utf8mb4
COLLATION = utf8mb4_unicode_ci
DEBUG = true
PREFIX = xmt_
TIMEOUT = 30
PERSISTENT = false
BREAK_RECONNECT = true
FIELDS_STRICT = true
FIELDS_CACHE = true
TRIGGER_SQL = true

# 数据库连接池配置
POOL.MIN_CONNECTIONS = 5
POOL.MAX_CONNECTIONS = 20
POOL.CONNECT_TIMEOUT = 10.0
POOL.WAIT_TIMEOUT = 3.0
POOL.HEARTBEAT = 60
POOL.MAX_IDLE_TIME = 60

# 从库配置（如需读写分离请填写）
SLAVE.TYPE = mysql
SLAVE.HOSTNAME = 127.0.0.1
SLAVE.DATABASE = xiaomotui
SLAVE.USERNAME = root
SLAVE.PASSWORD =
SLAVE.HOSTPORT = 3306
SLAVE.TIMEOUT = 30
SLAVE.PERSISTENT = false

# 读写分离配置
DEPLOY = 0
RW_SEPARATE = false
MASTER_NUM = 1
READ_MASTER = false

# 测试数据库配置
TEST.HOSTNAME = 127.0.0.1
TEST.DATABASE = xiaomotui_test
TEST.USERNAME = root
TEST.PASSWORD =
TEST.HOSTPORT = 3306

[REDIS]
HOST = 127.0.0.1
PORT = 6379
PASSWORD =
SELECT = 0
TIMEOUT = 5.0
READ_TIMEOUT = 3.0
EXPIRE = 0
PERSISTENT = false
PREFIX = xmt:
RETRY_TIMES = 3
RETRY_INTERVAL = 100

# Redis连接池配置
POOL.MIN_CONNECTIONS = 3
POOL.MAX_CONNECTIONS = 15
POOL.CONNECT_TIMEOUT = 10.0
POOL.WAIT_TIMEOUT = 3.0
POOL.HEARTBEAT = 30
POOL.MAX_IDLE_TIME = 60

# Redis选项配置
TCP_NODELAY = true
SO_SNDBUF = 262144
SO_RCVBUF = 262144
TCP_KEEPALIVE = true

# Redis集群配置（如使用集群请填写）
CLUSTER.NODE1 = 127.0.0.1:7000
CLUSTER.NODE2 = 127.0.0.1:7001
CLUSTER.NODE3 = 127.0.0.1:7002
CLUSTER.PASSWORD =
CLUSTER.TIMEOUT = 5.0
CLUSTER.READ_TIMEOUT = 3.0
CLUSTER.PREFIX = xmt:

[CACHE]
DRIVER = redis

[QUEUE]
DRIVER = redis

[SESSION]
TYPE = redis
AUTO_START = true

[LANG]
DEFAULT_LANG = zh-cn

[JWT]
SECRET_KEY = your_jwt_secret_key_here
EXPIRE_TIME = 86400
REFRESH_EXPIRE_TIME = 604800

[WECHAT]
APP_ID =
APP_SECRET =
MINI_APP_ID =
MINI_APP_SECRET =

[OSS]
ACCESS_ID =
ACCESS_SECRET =
BUCKET =
ENDPOINT =
URL =
PREFIX = xiaomotui/
IS_CNAME = false

[QINIU]
ACCESS_KEY =
SECRET_KEY =

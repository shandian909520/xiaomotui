# 生产环境配置

# 应用标题
VUE_APP_TITLE=小魔推碰一碰

# API基础地址
VUE_APP_API_BASE_URL=https://api.xiaomotui.com/api

# 环境标识
VUE_APP_ENV=production

# 是否开启调试
VUE_APP_DEBUG=false

# 是否开启mock数据
VUE_APP_MOCK=false

# 请求超时时间(毫秒)
VUE_APP_TIMEOUT=30000

# 文件上传地址
VUE_APP_UPLOAD_URL=https://api.xiaomotui.com/api/upload

# CDN地址
VUE_APP_CDN_URL=https://cdn.xiaomotui.com

# 微信AppID(正式号)
VUE_APP_WECHAT_APPID=

# 是否显示日志
VUE_APP_SHOW_LOG=false

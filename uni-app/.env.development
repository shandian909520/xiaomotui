# 开发环境配置

# 应用标题
VUE_APP_TITLE=小魔推碰一碰(开发)

# API基础地址
VUE_APP_API_BASE_URL=http://127.0.0.1:28080/api

# 环境标识
VUE_APP_ENV=development

# 是否开启调试
VUE_APP_DEBUG=true

# 是否开启mock数据
VUE_APP_MOCK=false

# 请求超时时间(毫秒)
VUE_APP_TIMEOUT=30000

# 文件上传地址
VUE_APP_UPLOAD_URL=http://127.0.0.1:28080/api/upload

# CDN地址(开发环境可留空)
VUE_APP_CDN_URL=

# 微信AppID(开发环境测试号)
VUE_APP_WECHAT_APPID=

# 是否显示日志
VUE_APP_SHOW_LOG=true

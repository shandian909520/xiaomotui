.container {
  padding: 0;
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 32rpx 80rpx;
  color: #fff;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 32rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  opacity: 0.9;
}

.features {
  padding: 0 32rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.feature-icon {
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 24rpx;
}

.feature-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.feature-desc {
  font-size: 28rpx;
  color: #7A7E83;
  text-align: center;
}

.quick-actions {
  padding: 48rpx 32rpx;
}

.quick-actions .btn {
  width: 100%;
  padding: 32rpx;
  font-size: 36rpx;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}
